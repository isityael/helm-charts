{
  "repositoryUrl": "https://github.com/sm-moshi/helm-charts.git",
  "branches": ["main"],
  "tagFormat": "cloudflared-v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/github",
      {
        "successComment": false,
        "failComment": false
      }
    ]
  ]
}
