{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "image": { "type": "object" },
    "persistence": { "type": "object" },
    "basicMemoryHome": { "type": "object" },
    "mcpShim": { "type": "object" },
    "obsidianSync": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "livesync": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "image": { "type": "object" },
            "configInitImage": { "type": "object" },
            "database": { "type": "string", "minLength": 1 },
            "existingSecret": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "passphraseKey": { "type": "string", "minLength": 1 }
              },
              "required": ["name", "passphraseKey"]
            },
            "scanOfflineChanges": { "type": "boolean" },
            "ignorePaths": {
              "type": "array",
              "items": { "type": "string" }
            },
            "resources": { "type": "object" }
          },
          "required": ["existingSecret"]
        }
      }
    },
    "service": { "type": "object" },
    "ingress": { "type": "object" },
    "httpRoute": { "type": "object" },
    "serviceAccount": { "type": "object" },
    "resources": { "type": "object" },
    "securityContext": { "type": "object" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "imagePullSecrets": { "type": "array" }
  }
}
