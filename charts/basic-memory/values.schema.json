{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests": { "$ref": "#/definitions/resourceList" },
        "limits": { "$ref": "#/definitions/resourceList" }
      }
    },
    "resourceList": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number"] }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 }
      },
      "required": ["initialDelaySeconds", "periodSeconds", "timeoutSeconds", "failureThreshold"]
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "storageClass": { "type": "string" },
        "accessMode": { "type": "string", "minLength": 1 },
        "size": { "type": "string", "minLength": 1 },
        "mountPath": { "type": "string", "pattern": "^/" }
      }
    },
    "secretReference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "userKey": { "type": "string", "minLength": 1 },
        "passwordKey": { "type": "string", "minLength": 1 },
        "passphraseKey": { "type": "string", "minLength": 1 }
      }
    },
    "tls": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hosts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "secretName": { "type": "string", "minLength": 1 }
      }
    },
    "parentRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "group": { "type": "string" },
        "kind": { "type": "string" },
        "name": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string" },
        "sectionName": { "type": "string" }
      },
      "required": ["name"]
    }
  },
  "properties": {
    "replicaCount": { "type": "integer", "minimum": 1 },
    "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "image": { "$ref": "#/definitions/image" },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": { "name": { "type": "string", "minLength": 1 } },
        "required": ["name"]
      }
    },
    "busyboxTools": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "image": { "$ref": "#/definitions/image" } },
      "required": ["image"]
    },
    "denoTools": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "image": { "$ref": "#/definitions/image" } },
      "required": ["image"]
    },
    "livesyncBridge": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "image": { "$ref": "#/definitions/image" } },
      "required": ["image"]
    },
    "basicMemory": {
      "type": "object",
      "additionalProperties": false,
      "properties": { "upstreamPort": { "type": "integer", "minimum": 1, "maximum": 65535 } },
      "required": ["upstreamPort"]
    },
    "env": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean"] }
    },
    "semanticSearch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "modelName": { "type": "string", "minLength": 1 },
        "cacheDir": { "type": "string", "pattern": "^/" }
      },
      "required": ["modelName", "cacheDir"]
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "targetPort": { "type": ["integer", "string"] },
        "ipFamilyPolicy": { "type": "string" },
        "ipFamilies": { "type": "array", "items": { "type": "string", "enum": ["IPv4", "IPv6"] }, "minItems": 1 }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "host": { "type": "string", "minLength": 1 },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "path": { "type": "string", "pattern": "^/" },
                    "pathType": { "type": "string", "enum": ["Exact", "Prefix", "ImplementationSpecific"] }
                  },
                  "required": ["path", "pathType"]
                }
              }
            },
            "required": ["host", "paths"]
          }
        },
        "tls": { "type": "array", "items": { "$ref": "#/definitions/tls" } }
      }
    },
    "httpRoute": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } },
        "parentRefs": { "type": "array", "items": { "$ref": "#/definitions/parentRef" } },
        "hostnames": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "rules": { "type": "array", "items": { "type": "object" } }
      }
    },
    "persistence": { "$ref": "#/definitions/persistence" },
    "basicMemoryHome": { "$ref": "#/definitions/persistence" },
    "resources": { "$ref": "#/definitions/resources" },
    "strategy": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "type": { "type": "string", "enum": ["Recreate", "RollingUpdate"] } },
      "required": ["type"]
    },
    "securityContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runAsNonRoot": { "type": "boolean" },
        "runAsUser": { "type": "integer", "minimum": 1 },
        "runAsGroup": { "type": "integer", "minimum": 1 },
        "fsGroup": { "type": "integer", "minimum": 1 }
      }
    },
    "startupProbe": { "$ref": "#/definitions/probe" },
    "livenessProbe": { "$ref": "#/definitions/probe" },
    "readinessProbe": { "$ref": "#/definitions/probe" },
    "pdb": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "maxUnavailable": { "type": ["integer", "string"] }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "annotations": { "type": "object", "additionalProperties": { "type": "string" } },
        "name": { "type": "string" }
      }
    },
    "nodeSelector": { "type": "object", "additionalProperties": { "type": "string" } },
    "tolerations": { "type": "array", "items": { "type": "object" } },
    "affinity": { "type": "object" },
    "mcpShim": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "$ref": "#/definitions/image" },
        "maxToolCallConcurrency": { "type": "integer", "minimum": 1 },
        "toolCallQueueTimeoutMs": { "type": "integer", "minimum": 1 },
        "upstreamTimeoutMs": { "type": "integer", "minimum": 1 },
        "throttledTools": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "blockedTools": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allowedNoteDirs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
            "allowDeleteNote": { "type": "boolean" }
          }
        },
        "resources": { "$ref": "#/definitions/resources" }
      }
    },
    "obsidianSync": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "couchdb": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "image": { "$ref": "#/definitions/image" },
            "cors": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "origins": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
                "methods": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true },
                "headers": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1, "uniqueItems": true },
                "credentials": { "type": "boolean" }
              },
              "required": ["enabled", "origins", "methods", "headers", "credentials"]
            },
            "existingSecret": {
              "allOf": [
                { "$ref": "#/definitions/secretReference" },
                { "required": ["name", "userKey", "passwordKey"] }
              ]
            },
            "persistence": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "size": { "type": "string", "minLength": 1 },
                "storageClass": { "type": "string" }
              },
              "required": ["size", "storageClass"]
            },
            "service": {
              "type": "object",
              "additionalProperties": false,
              "properties": { "port": { "type": "integer", "minimum": 1, "maximum": 65535 } },
              "required": ["port"]
            },
            "ingress": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "className": { "type": "string" },
                "annotations": { "type": "object", "additionalProperties": { "type": "string" } },
                "host": { "type": "string" },
                "tls": { "type": "array", "items": { "$ref": "#/definitions/tls" } }
              }
            },
            "httpRoute": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" },
                "annotations": { "type": "object", "additionalProperties": { "type": "string" } },
                "parentRefs": { "type": "array", "items": { "$ref": "#/definitions/parentRef" } },
                "hostnames": { "type": "array", "items": { "type": "string", "minLength": 1 } }
              }
            },
            "resources": { "$ref": "#/definitions/resources" }
          }
        },
        "livesync": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "image": { "$ref": "#/definitions/image" },
            "configInitImage": { "$ref": "#/definitions/image" },
            "database": { "type": "string", "minLength": 1 },
            "existingSecret": {
              "allOf": [
                { "$ref": "#/definitions/secretReference" },
                { "required": ["name", "passphraseKey"] }
              ]
            },
            "state": {
              "type": "object",
              "additionalProperties": false,
              "properties": { "dir": { "type": "string", "pattern": "^/app/data(?:/.*)?$" } },
              "required": ["dir"]
            },
            "health": {
              "type": "object",
              "additionalProperties": false,
              "properties": { "port": { "type": "integer", "minimum": 1, "maximum": 65535 } },
              "required": ["port"]
            },
            "probes": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "startup": { "$ref": "#/definitions/probe" },
                "readiness": { "$ref": "#/definitions/probe" },
                "liveness": { "$ref": "#/definitions/probe" }
              },
              "required": ["startup", "readiness", "liveness"]
            },
            "scanOfflineChanges": { "type": "boolean" },
            "ignorePaths": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
            "resources": { "$ref": "#/definitions/resources" }
          },
          "required": ["existingSecret", "state", "health", "probes"]
        }
      }
    }
  }
}
