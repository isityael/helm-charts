{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "replica": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allNodes": { "type": "boolean" },
        "count": { "type": "integer", "minimum": 0 }
      }
    },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
    "minReadySeconds": { "type": "integer", "minimum": 0 },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "tag": { "type": "string" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": { "type": "boolean" },
        "automount": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "livenessProbe": { "type": "object" },
    "startupProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "pdb": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "pattern": "^[0-9]+%$" }
          ]
        },
        "maxUnavailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "pattern": "^[0-9]+%$" }
          ]
        }
      },
      "not": {
        "required": ["minAvailable", "maxUnavailable"]
      }
    },
    "tunnelSecrets": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "existingSecret": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "credentialsKey": { "type": "string", "minLength": 1 },
            "certKey": { "type": "string", "minLength": 1 }
          }
        },
        "generatedSecretName": { "type": "string" },
        "base64EncodedPemFile": { "type": "string" },
        "base64EncodedConfigJsonFile": { "type": "string" },
        "existingPemFileSecret": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "key": { "type": "string", "minLength": 1 }
          }
        },
        "existingConfigJsonFileSecret": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "key": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "tunnelConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "metricsUpdateFrequency": { "type": "string", "pattern": "^[0-9]+(ns|us|ms|s|m|h)$" },
        "autoUpdateFrequency": { "type": "string", "pattern": "^[0-9]+(ns|us|ms|s|m|h)$" },
        "noAutoUpdate": { "type": "boolean" },
        "gracePeriod": { "type": "string", "pattern": "^[0-9]+(ns|us|ms|s|m|h)$" },
        "retries": { "type": "integer", "minimum": 0 },
        "protocol": { "type": "string", "enum": ["auto", "http2", "h2mux", "quic"] },
        "logLevel": { "type": "string", "enum": ["debug", "info", "warn", "error", "fatal", "panic"] },
        "transportLogLevel": { "type": "string", "enum": ["debug", "info", "warn", "error", "fatal", "panic"] },
        "connectTimeout": { "type": "string", "pattern": "^[0-9]+(ns|us|ms|s|m|h)$" },
        "warpRouting": { "type": "boolean" }
      }
    },
    "ingress": { "type": "array", "minItems": 1 },
    "resources": { "type": "object" },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "annotations": { "type": "object" },
            "labels": { "type": "object" }
          }
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "annotations": { "type": "object" },
            "labels": { "type": "object" },
            "interval": { "type": "string", "pattern": "^[0-9]+(ns|us|ms|s|m|h)$" },
            "scrapeTimeout": { "type": "string", "pattern": "^[0-9]+(ns|us|ms|s|m|h)$" },
            "relabelings": { "type": "array" },
            "metricRelabelings": { "type": "array" }
          }
        }
      }
    },
    "extraEnv": { "type": "array" },
    "extraVolumeMounts": { "type": "array" },
    "extraVolumes": { "type": "array" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "topologySpreadConstraints": { "type": "array" },
    "affinity": { "type": "object" }
  }
}
