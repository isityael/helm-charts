{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "matrixUmbrella": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "imageProfile": {
          "type": "string",
          "enum": ["dhi", "upstream"],
          "default": "dhi"
        }
      }
    },
    "serverName": { "type": "string" },
    "homeserverUrl": { "type": "string" },
    "ess": { "type": "object" },
    "cinny": { "type": "object" },
    "mautrix-discord": { "type": "object" },
    "mautrix-signal": { "type": "object" },
    "mautrix-telegram": { "type": "object" },
    "mautrix-whatsapp": { "type": "object" },
    "matrix-appservice-irc": { "type": "object" }
  }
}
