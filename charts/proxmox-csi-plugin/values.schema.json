{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "replicaCount": { "type": "integer", "minimum": 0 },
    "imagePullSecrets": { "type": "array" },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "createNamespace": { "type": "boolean" },
    "priorityClassName": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "provisionerName": { "type": "string" },
    "clusterID": { "type": "string" },
    "logVerbosityLevel": { "type": "integer", "minimum": 0 },
    "timeout": { "type": "string" },
    "options": {
      "type": "object",
      "properties": {
        "enableCapacity": { "type": "boolean" }
      }
    },
    "existingConfigSecret": {
      "type": ["string", "null"]
    },
    "existingConfigSecretKey": { "type": "string" },
    "configFile": { "type": "string" },
    "config": { "type": "object" },
    "storageClass": { "type": "array" },
    "controller": { "$ref": "#/definitions/componentGroup" },
    "node": { "$ref": "#/definitions/componentGroup" },
    "livenessprobe": {
      "type": "object",
      "properties": {
        "image": { "$ref": "#/definitions/image" },
        "failureThreshold": { "type": "integer", "minimum": 1 },
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "resources": { "type": "object" }
      }
    },
    "initContainers": { "type": "array" },
    "hostAliases": { "type": "array" },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "updateStrategy": { "type": "object" },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "type": { "type": "string" }
      }
    },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "extraVolumes": { "type": "array" },
    "extraVolumeMounts": { "type": "array" }
  },
  "definitions": {
    "pullPolicy": {
      "type": "string",
      "enum": ["Always", "IfNotPresent", "Never"]
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "pullPolicy": { "$ref": "#/definitions/pullPolicy" },
        "tag": { "type": "string" }
      }
    },
    "sidecar": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "$ref": "#/definitions/image" },
        "args": { "type": "array", "items": { "type": "string" } },
        "resources": { "type": "object" }
      }
    },
    "componentGroup": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "plugin": { "$ref": "#/definitions/sidecar" },
        "attacher": { "$ref": "#/definitions/sidecar" },
        "provisioner": { "$ref": "#/definitions/sidecar" },
        "resizer": { "$ref": "#/definitions/sidecar" },
        "snapshotter": { "$ref": "#/definitions/sidecar" },
        "driverRegistrar": { "$ref": "#/definitions/sidecar" },
        "kubeletDir": { "type": "string" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" }
      }
    }
  }
}
