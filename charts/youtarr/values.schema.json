{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "revisionHistoryLimit": {
      "type": "integer",
      "minimum": 0
    },
    "strategy": {
      "type": "object",
      "additionalProperties": true
    },
    "image": {
      "type": "object",
      "required": ["repository", "pullPolicy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "digest": {
          "type": "string",
          "pattern": "^(|sha256:[a-f0-9]{64})$"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "youtarr": {
      "type": "object",
      "properties": {
        "timezone": { "type": "string", "minLength": 1 },
        "uid": { "type": "integer", "minimum": 0 },
        "gid": { "type": "integer", "minimum": 0 },
        "logLevel": { "type": "string" },
        "trustProxy": { "type": "string" },
        "dataPath": { "type": "string" }
      }
    },
    "auth": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "presetExistingSecret": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "usernameKey": { "type": "string", "minLength": 1 },
            "passwordKey": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "database": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["embedded", "external"]
        }
      }
    },
    "mariadb": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "required": ["repository", "tag", "pullPolicy"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string", "minLength": 1 },
            "digest": {
              "type": "string",
              "pattern": "^(|sha256:[a-f0-9]{64})$"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "auth": {
          "type": "object",
          "properties": {
            "database": { "type": "string", "minLength": 1 },
            "username": { "type": "string", "minLength": 1 },
            "existingSecret": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "rootPasswordKey": { "type": "string", "minLength": 1 },
                "passwordKey": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "persistence": { "$ref": "#/definitions/persistenceClaim" },
        "podSecurityContext": { "type": "object" },
        "securityContext": { "type": "object" },
        "resources": { "type": "object" }
      }
    },
    "externalDatabase": {
      "type": "object",
      "properties": {
        "host": { "type": "string" },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "database": { "type": "string", "minLength": 1 },
        "username": { "type": "string", "minLength": 1 },
        "existingSecret": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "passwordKey": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "automount": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "service": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "containerPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "downloads": { "$ref": "#/definitions/downloadsPersistence" },
        "config": { "$ref": "#/definitions/persistenceClaim" },
        "jobs": { "$ref": "#/definitions/persistenceClaim" },
        "images": { "$ref": "#/definitions/persistenceClaim" }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["host", "paths"],
            "properties": {
              "host": { "type": "string", "minLength": 1 },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["path", "pathType"],
                  "properties": {
                    "path": { "type": "string", "minLength": 1 },
                    "pathType": {
                      "type": "string",
                      "enum": ["Exact", "Prefix", "ImplementationSpecific"]
                    }
                  }
                }
              }
            }
          }
        },
        "tls": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "httpRoute": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "annotations": { "type": "object" },
        "parentRefs": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "hostnames": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "probes": {
      "type": "object",
      "properties": {
        "liveness": { "type": "object" },
        "readiness": { "type": "object" }
      }
    },
    "resources": { "type": "object" },
    "extraEnv": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "nodeSelector": { "type": "object" },
    "tolerations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "affinity": { "type": "object" }
  },
  "definitions": {
    "persistenceClaim": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "storageClass": { "type": "string" },
        "size": { "type": "string", "minLength": 1 },
        "accessMode": { "type": "string", "minLength": 1 },
        "existingClaim": { "type": "string" }
      }
    },
    "downloadsPersistence": {
      "allOf": [
        { "$ref": "#/definitions/persistenceClaim" },
        {
          "type": "object",
          "properties": {
            "hostPath": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "path": { "type": "string" },
                "type": { "type": "string" }
              }
            }
          }
        }
      ]
    }
  }
}
