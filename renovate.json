{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "https://git.m0sh1.cc/m0sh1/infra/raw/branch/main/.github/renovate/base.json",
    "config:best-practices",
    ":preserveSemverRanges",
    "helpers:pinGitHubActionDigests"
  ],
  "pinDigests": false,
  "schedule": ["before 04:00 on monday"],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 2,
  "rangeStrategy": "bump",
  "enabledManagers": [
    "helmv3",
    "helm-values",
    "github-actions",
    "npm"
  ],
  "ignorePaths": [
    "charts/**/charts/**"
  ],
  "lockFileMaintenance": {
    "enabled": false
  },
  "bumpVersions": [
    {
      "name": "Bump chart version for chart dependency updates",
      "filePatterns": ["{{packageFileDir}}/Chart.yaml"],
      "matchStrings": ["version:\\s*(?<version>[^\\s]+)"],
      "bumpType": "patch"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["helmv3", "helm-values"],
      "groupName": "Helm charts",
      "groupSlug": "helm-charts",
      "separateMinorPatch": true,
      "labels": ["dependencies", "helm"]
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions",
      "separateMinorPatch": true,
      "labels": ["dependencies", "ci"]
    },
    {
      "matchManagers": ["npm"],
      "groupName": "npm dependencies",
      "groupSlug": "npm-deps",
      "labels": ["dependencies", "npm"]
    }
  ]
}
