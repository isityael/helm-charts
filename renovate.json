{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>isityael/infra//.github/renovate/base.json",
    "config:best-practices",
    ":preserveSemverRanges",
    "helpers:pinGitHubActionDigests"
  ],
  "pinDigests": false,
  "prHourlyLimit": 2,
  "prConcurrentLimit": 2,
  "rangeStrategy": "bump",
  "enabledManagers": [
    "helmv3",
    "helm-values",
    "custom.regex",
    "github-actions",
    "npm"
  ],
  "ignorePaths": [
    "charts/**/charts/**"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "DHI images in non-standard YAML keys for public charts",
      "managerFilePatterns": [
        "/charts/.+/values(?:-[^/]+)?\\.yaml$/",
        "/charts/.+/ci/.+\\.yaml$/",
        "/charts/.+/examples/.+\\.yaml$/"
      ],
      "matchStrings": [
        ":\\s*[\"']?(?<depName>dhi\\.io/[^:\"'\\s]+):(?<currentValue>[^@\"'\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?[\"']?"
      ],
      "autoReplaceStringTemplate": ": {{{depName}}}:{{{newValue}}}{{#if newDigest}}@{{{newDigest}}}{{/if}}",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Images with sibling digest keys",
      "managerFilePatterns": [
        "/charts/matrix-umbrella/values(?:-[^/]+)?\\.yaml$/",
        "/charts/youtarr/values(?:-[^/]+)?\\.yaml$/"
      ],
      "matchStrings": [
        "(?<indent>[ \\t]*)(?:registry:\\s*(?<imageRegistry>[^\\s\\\"']+)\\s+)?repository:\\s*(?<imageRepository>[^\\s\\\"']+)\\s+tag:\\s*[\\\"']?(?<currentValue>[^@\\\"'\\s]+)[\\\"']?\\s+digest:\\s*(?<currentDigest>sha256:[a-f0-9]+)"
      ],
      "depNameTemplate": "{{#if imageRegistry}}{{{imageRegistry}}}/{{/if}}{{{imageRepository}}}",
      "autoReplaceStringTemplate": "{{{indent}}}{{#if imageRegistry}}registry: {{{imageRegistry}}}\n{{{indent}}}{{/if}}repository: {{{imageRepository}}}\n{{{indent}}}tag: \"{{{newValue}}}\"\n{{{indent}}}digest: {{{newDigest}}}",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Full image references in the csi-s3 wrapper",
      "managerFilePatterns": [
        "/charts/csi-s3/values\\.yaml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>docker) depName=(?<depName>[^\\s]+)\\n(?<indent>[ \\t]+)(?<key>[a-zA-Z]+): [^\\s:]+:(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      "autoReplaceStringTemplate": "# renovate: datasource=docker depName={{{depName}}}\n{{{indent}}}{{{key}}}: {{{depName}}}:{{{newValue}}}{{#if newDigest}}@{{{newDigest}}}{{/if}}"
    }
  ],
  "lockFileMaintenance": {
    "enabled": false
  },
  "bumpVersions": [
    {
      "name": "Bump chart version for chart dependency updates",
      "filePatterns": ["{{packageFileDir}}/Chart.yaml"],
      "matchStrings": ["version:\\s*\"?v?(?<version>\\d+\\.\\d+\\.\\d+)\"?"],
      "bumpType": "patch"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["helmv3", "helm-values"],
      "groupName": "Helm charts",
      "groupSlug": "helm-charts",
      "separateMinorPatch": true,
      "labels": ["dependencies", "helm"]
    },
    {
      "description": "Refresh committed locks and vendored archives for every chart dependency update",
      "matchManagers": ["helmv3"],
      "postUpgradeTasks": {
        "commands": ["helm dependency update {{{packageFileDir}}}"],
        "fileFilters": [
          "{{{packageFileDir}}}/Chart.lock",
          "{{{packageFileDir}}}/charts/**"
        ],
        "executionMode": "update",
        "installTools": {
          "helm": {}
        }
      }
    },
    {
      "description": "Keep matrix-umbrella chart dependencies and vendored archives in sync",
      "matchManagers": ["helmv3"],
      "matchFileNames": ["charts/matrix-umbrella/Chart.yaml"],
      "groupName": "matrix-umbrella helm deps",
      "labels": ["dependencies", "helm", "matrix"],
      "bumpVersions": [
        {
          "name": "Patch-bump matrix-umbrella for chart dependency updates",
          "filePatterns": ["charts/matrix-umbrella/Chart.yaml"],
          "matchStrings": ["version:\\s*\"?v?(?<version>\\d+\\.\\d+\\.\\d+)\"?"],
          "bumpType": "patch"
        }
      ]
    },
    {
      "description": "Keep csi-s3 upstream dependency and vendored archive in sync",
      "matchManagers": ["helmv3"],
      "matchFileNames": ["charts/csi-s3/Chart.yaml"],
      "groupName": "csi-s3 upstream chart",
      "labels": ["dependencies", "helm", "csi-s3"],
      "bumpVersions": [
        {
          "name": "Patch-bump csi-s3 for upstream chart updates",
          "filePatterns": ["charts/csi-s3/Chart.yaml"],
          "matchStrings": ["version:\\s*\"?v?(?<version>\\d+\\.\\d+\\.\\d+)\"?"],
          "bumpType": "patch"
        }
      ]
    },
    {
      "description": "Patch-bump csi-s3 when its image references change",
      "matchManagers": ["custom.regex"],
      "matchFileNames": ["charts/csi-s3/values.yaml"],
      "groupName": "csi-s3 images",
      "labels": ["dependencies", "docker", "csi-s3"],
      "bumpVersions": [
        {
          "name": "Patch-bump csi-s3 for image updates",
          "filePatterns": ["charts/csi-s3/Chart.yaml"],
          "matchStrings": ["version:\\s*\"?v?(?<version>\\d+\\.\\d+\\.\\d+)\"?"],
          "bumpType": "patch"
        }
      ]
    },
    {
      "description": "Group matrix-umbrella DHI image updates",
      "matchManagers": ["helm-values", "custom.regex"],
      "matchDatasources": ["docker"],
      "matchFileNames": [
        "charts/matrix-umbrella/values*.yaml",
        "charts/matrix-umbrella/ci/**",
        "charts/matrix-umbrella/examples/**"
      ],
      "matchPackageNames": ["/^dhi\\.io\\//"],
      "groupName": "matrix-umbrella DHI images",
      "labels": ["dependencies", "docker", "dhi", "matrix"],
      "bumpVersions": [
        {
          "name": "Patch-bump matrix-umbrella for DHI image updates",
          "filePatterns": ["charts/matrix-umbrella/Chart.yaml"],
          "matchStrings": ["version:\\s*\"?v?(?<version>\\d+\\.\\d+\\.\\d+)\"?"],
          "bumpType": "patch"
        }
      ]
    },
    {
      "description": "Group matrix-umbrella upstream Matrix image updates",
      "matchManagers": ["helm-values"],
      "matchDatasources": ["docker"],
      "matchFileNames": ["charts/matrix-umbrella/values*.yaml"],
      "matchPackageNames": [
        "oci.element.io/synapse",
        "oci.element.io/element-web",
        "ghcr.io/element-hq/matrix-authentication-service",
        "ghcr.io/element-hq/ess-helm/matrix-tools",
        "ghcr.io/cinnyapp/cinny",
        "/^dock\\.mau\\.dev\\/mautrix\\//",
        "matrixdotorg/matrix-appservice-irc"
      ],
      "groupName": "matrix-umbrella upstream images",
      "labels": ["dependencies", "docker", "matrix"],
      "bumpVersions": [
        {
          "name": "Patch-bump matrix-umbrella for upstream image updates",
          "filePatterns": ["charts/matrix-umbrella/Chart.yaml"],
          "matchStrings": ["version:\\s*\"?v?(?<version>\\d+\\.\\d+\\.\\d+)\"?"],
          "bumpType": "patch"
        }
      ]
    },
    {
      "description": "Keep split image digests out of tag values",
      "matchManagers": ["helm-values"],
      "matchDatasources": ["docker"],
      "matchFileNames": [
        "charts/matrix-umbrella/values*.yaml",
        "charts/youtarr/values*.yaml"
      ],
      "matchPackageNames": [
        "dhi.io/busybox",
        "dhi.io/haproxy",
        "dhi.io/mariadb",
        "dhi.io/postgres",
        "dhi.io/valkey",
        "ghcr.io/cinnyapp/cinny",
        "ghcr.io/element-hq/ess-helm/matrix-tools",
        "ghcr.io/element-hq/matrix-authentication-service",
        "oci.element.io/element-web",
        "oci.element.io/synapse",
        "/^dock\\.mau\\.dev\\/mautrix\\//"
      ],
      "pinDigests": false
    },
    {
      "description": "Patch-bump chart versions when Renovate changes chart values",
      "matchManagers": ["helm-values"],
      "matchFileNames": ["charts/**/values*.yaml"],
      "bumpVersions": [
        {
          "name": "Patch-bump adjacent Helm Chart.yaml",
          "filePatterns": ["{{packageFileDir}}/Chart.yaml"],
          "matchStrings": ["version:\\s*\"?v?(?<version>\\d+\\.\\d+\\.\\d+)\"?"],
          "bumpType": "patch"
        }
      ]
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions",
      "separateMinorPatch": true,
      "labels": ["dependencies", "ci"]
    },
    {
      "matchManagers": ["npm"],
      "groupName": "npm dependencies",
      "groupSlug": "npm-deps",
      "labels": ["dependencies", "npm"]
    }
  ]
}
